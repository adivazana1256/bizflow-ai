# App connection — RLS-subject role. Used by all runtime queries via withTenant().
DATABASE_URL=postgres://bizflow_app:app_password@localhost:5432/bizflow

# Admin connection — superuser. Used ONLY for migrations and auth bootstrap
# (signup + login email lookup). Bypasses RLS by design.
ADMIN_DATABASE_URL=postgres://postgres:postgres@localhost:5432/bizflow

# Auth.js
AUTH_SECRET=change-me-to-a-random-32-byte-secret
AUTH_TRUST_HOST=true
