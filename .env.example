# Single DB connection. One business per deployment — no RLS, no admin/app split.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bizflow

# Auth.js (staff login for the approval panel)
AUTH_SECRET=change-me-to-a-random-32-byte-secret
AUTH_TRUST_HOST=true

# WhatsApp Cloud API (Meta) — see docs/WHATSAPP_ARCHITECTURE.md
WHATSAPP_VERIFY_TOKEN=change-me-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v21.0

# Claude AI-Employee (see docs/CLAUDE_BRAIN.md). Leave ANTHROPIC_API_KEY unset
# to run the deterministic flow engine instead — no Claude calls are made.
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-opus-4-8
